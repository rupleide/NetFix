<Window x:Class="NetFix.Views.ZapretConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройка конфига Zapret"
        Height="500" Width="550"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Settings Icon -->
        <PathGeometry x:Key="SettingsIcon">M12,8 A4,4 0 1,1 12,16 A4,4 0 1,1 12,8 M12,2 L12,6 M12,18 L12,22 M4.93,4.93 L7.76,7.76 M16.24,16.24 L19.07,19.07 M2,12 L6,12 M18,12 L22,12 M4.93,19.07 L7.76,16.24 M16.24,7.76 L19.07,4.93</PathGeometry>
        
        <!-- Checkmark Icon -->
        <PathGeometry x:Key="CheckmarkIcon">M2,12 L8,18 L22,4</PathGeometry>
        
        <!-- Warning Icon -->
        <PathGeometry x:Key="WarningIcon">M12,2 L22,20 L2,20 Z M12,9 L12,13 M12,15 L12,17</PathGeometry>
        
        <!-- ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#333333" CornerRadius="5" Width="5" HorizontalAlignment="Right" Margin="0,4,2,4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="#1e1e1e" CornerRadius="12" BorderBrush="#2e2e2e" BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Path Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"
                      Data="{StaticResource SettingsIcon}" Stroke="#888888" StrokeThickness="1.5"/>
                <TextBlock Text="Настройка конфига Zapret" FontSize="16" FontWeight="SemiBold"
                           Foreground="#f0f0f0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Status Panel -->
            <StackPanel x:Name="StatusPanel" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                <Path x:Name="StatusIcon" Width="16" Height="16" Stretch="Uniform" 
                      VerticalAlignment="Top" Margin="0,2,10,0" Visibility="Collapsed"/>
                <TextBlock x:Name="StatusText"
                           Text="Запуск тестирования..."
                           Foreground="White" FontSize="13"
                           TextWrapping="Wrap"
                           MaxWidth="450"/>
            </StackPanel>

            <!-- Progress Bar -->
            <Border Grid.Row="2" Height="6" CornerRadius="3" Background="#252525" Margin="0,0,0,16"
                    ClipToBounds="True" x:Name="ProgressBarContainer">
                <Border x:Name="IndeterminateBar" Height="6" CornerRadius="3"
                        Background="#3b82f6" HorizontalAlignment="Left" Width="80">
                    <Border.Effect>
                        <DropShadowEffect Color="#3b82f6" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                    </Border.Effect>
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="BarTranslate"/>
                    </Border.RenderTransform>
                </Border>
            </Border>

            <!-- Log TextBox -->
            <Border Grid.Row="3" Background="#252525" CornerRadius="8" 
                    BorderBrush="#333333" BorderThickness="1"
                    x:Name="LogContainer" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0">
                    <TextBox x:Name="LogTextBox"
                             Background="Transparent"
                             Foreground="#f0f0f0"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             Padding="12"
                             VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </Border>

            <!-- Config List (ScrollViewer) -->
            <ScrollViewer x:Name="ConfigListScroll" Grid.Row="3" 
                          VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed"
                          Margin="0,0,0,0">
                <StackPanel x:Name="ConfigListPanel"/>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel x:Name="ButtonPanel" Grid.Row="4"
                        Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button x:Name="SecondaryBtn" Content="Отмена"
                        Width="120" Height="36" Margin="0,0,10,0"
                        Background="Transparent" Foreground="#888888"
                        BorderBrush="#333333" BorderThickness="1"
                        Cursor="Hand" Click="SecondaryBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#252525"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="PrimaryBtn" Content="Повторить тест"
                        Width="140" Height="36"
                        Background="#3b82f6" Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand" Click="PrimaryBtn_Click"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4a90ff"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
