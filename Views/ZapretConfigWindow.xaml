        <!-- Plug Icon -->
        <PathGeometry x:Key="PlugIcon">M6 0a.5.5 0 0 1 .5.5V3h3V.5a.5.5 0 0 1 1 0V3h1a.5.5 0 0 1 .5.5v3A3.5 3.5 0 0 1 8.5 10c-.002.434-.01.845-.04 1.22-.041.514-.126 1.003-.317 1.424a2.083 2.083 0 0 1-.97 1.028C6.725 13.9 6.169 14 5.5 14c-.998 0-1.61.33-1.974.718A1.922 1.922 0 0 0 3 16H2c0-.616.232-1.367.797-1.968C3.374 13.42 4.261 13 5.5 13c.581 0 .962-.088 1.218-.219.241-.123.4-.3.514-.55.121-.266.193-.621.23-1.09.027-.34.035-.718.037-1.141A3.5 3.5 0 0 1 4 6.5v-3a.5.5 0 0 1 .5-.5h1V.5A.5.5 0 0 1 6 0zM5 4v2.5A2.5 2.5 0 0 0 7.5 9h1A2.5 2.5 0 0 0 11 6.5V4H5z</PathGeometry>
        
        <!-- Checkmark Icon -->
        <PathGeometry x:Key="CheckmarkIcon">M2,12 L8,18 L22,4</PathGeometry>
        
        <!-- Warning Icon -->
        <PathGeometry x:Key="WarningIcon">M12,2 L22,20 L2,20 Z M12,9 L12,13 M12,15 L12,17</PathGeometry>
        
        <!-- ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#333333" CornerRadius="5" Width="5" HorizontalAlignment="Right" Margin="0,4,2,4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="#1e1e1e" CornerRadius="12" BorderBrush="#2e2e2e" BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Path Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"
                      Data="{StaticResource SettingsIcon}" Fill="#888888"/>
                <TextBlock Text="Настройка конфига Zapret" FontSize="16" FontWeight="SemiBold"
                           Foreground="#f0f0f0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Status Panel -->
            <StackPanel x:Name="StatusPanel" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                <Path x:Name="StatusIcon" Width="16" Height="16" Stretch="Uniform" 
                      VerticalAlignment="Top" Margin="0,2,10,0" Visibility="Collapsed"/>
                <TextBlock x:Name="StatusText"
                           Text="Запуск тестирования..."
                           Foreground="White" FontSize="13"
                           TextWrapping="Wrap"
                           MaxWidth="450"/>
            </StackPanel>

            <!-- Progress Text -->
            <TextBlock x:Name="ProgressText" Grid.Row="2" 
                       Text="" 
                       Foreground="White" 
                       FontSize="11"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="0,0,0,6"
                       Visibility="Collapsed"/>
            
            <!-- Time Remaining Text -->
            <TextBlock x:Name="TimeRemainingText" Grid.Row="2" 
                       Text="" 
                       Foreground="#888888" 
                       FontSize="11"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,0,0,6"
                       Visibility="Collapsed"/>
            
            <!-- Progress Bar -->
            <Border Grid.Row="2" Height="6" CornerRadius="3" Background="#252525" Margin="0,20,0,16"
                    ClipToBounds="True" x:Name="ProgressBarContainer">
                <Border x:Name="ProgressBar" Height="6" CornerRadius="3"
                        Background="#3b82f6" HorizontalAlignment="Left" Width="0">
                    <Border.Effect>
                        <DropShadowEffect Color="#3b82f6" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                    </Border.Effect>
                </Border>
            </Border>

            <!-- Log TextBox -->
            <Border Grid.Row="3" Background="#252525" CornerRadius="8" 
                    BorderBrush="#333333" BorderThickness="1"
                    x:Name="LogContainer" Visibility="Collapsed">
                <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Margin="0">
                    <RichTextBox x:Name="LogTextBox"
                                 Background="Transparent"
                                 Foreground="#f0f0f0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Padding="12"
                                 VerticalScrollBarVisibility="Disabled"
                                 IsDocumentEnabled="True"/>
                </ScrollViewer>
            </Border>

            <!-- Config List (ScrollViewer) -->
            <ScrollViewer x:Name="ConfigListScroll" Grid.Row="3" 
                          VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed"
                          Margin="0,0,0,0">
                <StackPanel x:Name="ConfigListPanel"/>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel x:Name="ButtonPanel" Grid.Row="4"
                        Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button x:Name="SecondaryBtn" Content="Отмена"
                        Width="120" Height="36" Margin="0,0,10,0"
                        Background="Transparent" Foreground="#888888"
                        BorderBrush="#333333" BorderThickness="1"
                        Cursor="Hand" Click="SecondaryBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#252525"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="PrimaryBtn" Content="Повторить тест"
                        Width="140" Height="36"
                        Background="#3b82f6" Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand" Click="PrimaryBtn_Click"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4a90ff"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
