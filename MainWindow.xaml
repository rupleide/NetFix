                                        FontSize="12" Padding="0,4"
                                        WindowChrome.IsHitTestVisibleInChrome="True"
                                        Click="LinkTgWs_Click"/>
                                <Button Content="↗ NetFix на GitHub" HorizontalAlignment="Left"
