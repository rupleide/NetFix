                </Grid>
            </Border>

            <!-- ══════════════════ SERVICES PANEL ══════════════════ -->
            <Grid Grid.Row="0" Grid.RowSpan="3" x:Name="ServicesLayer"
                  Visibility="Collapsed" Panel.ZIndex="14">
                <Rectangle Fill="Black" Opacity="0.4"
                           MouseLeftButtonDown="ServicesBackdrop_Click"/>
                <Border x:Name="ServicesPanel" Width="300"
                        HorizontalAlignment="Right"
                        Background="#1e1e1e" CornerRadius="12,0,0,12"
                        BorderBrush="#333333" BorderThickness="1,0,0,0">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ServicesTrans" X="300"/>
                    </Border.RenderTransform>
                    <DockPanel>

                        <!-- Заголовок -->
                        <Border DockPanel.Dock="Top" Height="54"
                                BorderBrush="#333333" BorderThickness="0,0,0,1">
                            <Grid Margin="20,0">
                                <TextBlock Text="Управление сервисами"
                                           FontFamily="Segoe UI" FontSize="15"
                                           FontWeight="Bold" Foreground="White"
                                           VerticalAlignment="Center"/>
                                <Button Content="✕" HorizontalAlignment="Right"
                                        Style="{StaticResource FlatBtnCentered}"
                                        FontSize="14" Padding="0" Width="34" Height="34"
                                        VerticalAlignment="Center"
                                        WindowChrome.IsHitTestVisibleInChrome="True"
                                        Click="ServicesCloseBtn_Click"/>
                            </Grid>
                        </Border>

                        <!-- Контент -->
                        <StackPanel Margin="20,20,20,24">

                            <!-- Zapret -->
                            <Border Background="#252525" CornerRadius="12"
                                    BorderBrush="#333333" BorderThickness="1"
                                    Padding="16,14" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38" CornerRadius="10"
                                            Background="#1a2a3a" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="Z" FontFamily="Segoe UI"
                                                   FontSize="17" FontWeight="Bold"
                                                   Foreground="#3b82f6"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Zapret"
                                                   FontFamily="Segoe UI" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="White"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <Ellipse x:Name="ZapretDot2" Width="6" Height="6"
                                                     Fill="#888888" VerticalAlignment="Center"
                                                     Margin="0,0,5,0"/>
                                            <TextBlock x:Name="ZapretStatusLbl"
                                                       Text="Не запущен"
                                                       FontFamily="Segoe UI" FontSize="11"
                                                       Foreground="#888888"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button x:Name="ZapretToggleBtn" Grid.Column="2"
                                            Content="▶  Запустить"
                                            Style="{StaticResource AccentBtn}"
                                            Padding="12,7" FontSize="12"
                                            WindowChrome.IsHitTestVisibleInChrome="True"
                                            Click="ZapretToggle_Click"/>
                                </Grid>
                            </Border>

                            <!-- tg-ws-proxy -->
                            <Border Background="#252525" CornerRadius="12"
                                    BorderBrush="#333333" BorderThickness="1"
                                    Padding="16,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38" CornerRadius="10"
                                            Background="#1a2a3a" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="T" FontFamily="Segoe UI"
                                                   FontSize="17" FontWeight="Bold"
                                                   Foreground="#3b82f6"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="tg-ws-proxy"
                                                   FontFamily="Segoe UI" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="White"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <Ellipse x:Name="TgWsDot2" Width="6" Height="6"
                                                     Fill="#888888" VerticalAlignment="Center"
                                                     Margin="0,0,5,0"/>
                                            <TextBlock x:Name="TgWsStatusLbl"
                                                       Text="Не запущен"
                                                       FontFamily="Segoe UI" FontSize="11"
                                                       Foreground="#888888"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button x:Name="TgWsToggleBtn" Grid.Column="2"
                                            Content="▶  Запустить"
                                            Style="{StaticResource AccentBtn}"
                                            Padding="12,7" FontSize="12"
                                            WindowChrome.IsHitTestVisibleInChrome="True"
                                            Click="TgWsToggle_Click"/>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
