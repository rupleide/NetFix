                                Click="CloseBtn_Click">
                            <Path Data="{StaticResource CloseIcon}" 
                                  Stroke="#888888"
                                  StrokeThickness="2"
                                  
                                  Width="12" Height="12"
                                  Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════ CONTENT ══════════════════ -->
            <Grid Grid.Row="1" x:Name="ContentGrid">

                <!-- ── MAIN PAGE ── -->
                <ScrollViewer x:Name="MainPage" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32,24,32,24">

                        <!-- Title -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <Path Data="{StaticResource BoltIcon}" 
                                  Fill="White"
                                  Width="20" Height="20"
                                  Stretch="Uniform"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Починить Telegram и Discord"
                                       FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Одна кнопка - скачает, настроит и запустит всё необходимое."
                                   FontFamily="Segoe UI" FontSize="13" Foreground="#888888"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,24"/>

                        <!-- Round power button, enhanced animation system -->
                        <Grid HorizontalAlignment="Center" Width="200" Height="200" Margin="0,0,0,8">

                            <Button x:Name="FixBtn"
                                    Style="{StaticResource BigBtn}"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Click="FixBtn_Click">
                                <Path Data="{StaticResource PowerIcon}" 
                                      Stroke="White" 
                                      StrokeThickness="3" 
                                      Width="32" Height="32"
                                      Stretch="Uniform"/>
                            </Button>

                            <!-- Idle: статические кольца -->
                            <Ellipse x:Name="IdleRingOuter" Width="188" Height="188"
                                     Stroke="#3b82f6" StrokeThickness="2.5" Fill="Transparent"
                                     IsHitTestVisible="False" Opacity="0.5"/>
                            <Ellipse x:Name="IdleRingInner" Width="174" Height="174"
                                     Stroke="#3b82f6" StrokeThickness="0.8"
                                     StrokeDashArray="6 8" Fill="Transparent"
                                     IsHitTestVisible="False" Opacity="0.2"/>

                            <!-- Loading: пульсирующие гало -->
                            <Ellipse x:Name="PulseRing1" Width="180" Height="180"
                                     Stroke="#5b8df5" StrokeThickness="6" Fill="Transparent"
                                     IsHitTestVisible="False" Visibility="Collapsed" Opacity="0.15"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="PulseScale1" ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="PulseRing2" Width="210" Height="210"
                                     Stroke="#5b8df5" StrokeThickness="4" Fill="Transparent"
                                     IsHitTestVisible="False" Visibility="Collapsed" Opacity="0.08"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="PulseScale2" ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>

                            <!-- Loading: спиннер 1 (синий, по часовой) -->
                            <Ellipse x:Name="SpinArc" Width="188" Height="188"
                                     Stroke="#5b8df5" StrokeThickness="3"
                                     StrokeDashArray="200 430" StrokeDashCap="Round"
                                     Fill="Transparent" RenderTransformOrigin="0.5,0.5"
                                     IsHitTestVisible="False" Visibility="Collapsed">
                                <Ellipse.RenderTransform>
                                    <TransformGroup>
                                        <RotateTransform x:Name="SpinRotation" Angle="-90"/>
                                        <RotateTransform x:Name="SpinOffset" Angle="0"/>
                                    </TransformGroup>
                                </Ellipse.RenderTransform>
                            </Ellipse>

                            <!-- Loading: спиннер 2 (фиолетовый, против часовой) -->
                            <Ellipse x:Name="SpinArc2" Width="174" Height="174"
                                     Stroke="#7c6af7" StrokeThickness="2"
                                     StrokeDashArray="80 550" StrokeDashCap="Round"
                                     Fill="Transparent" RenderTransformOrigin="0.5,0.5"
                                     IsHitTestVisible="False" Visibility="Collapsed">
                                <Ellipse.RenderTransform>
                                    <TransformGroup>
                                        <RotateTransform Angle="60"/>
                                        <RotateTransform x:Name="SpinRotation2" Angle="0"/>
                                    </TransformGroup>
                                </Ellipse.RenderTransform>
                            </Ellipse>

                            <!-- Success: заполняющаяся дуга -->
                            <Ellipse x:Name="SuccessArc" Width="188" Height="188"
                                     Stroke="#22c55e" StrokeThickness="3" StrokeDashCap="Round"
                                     Fill="Transparent" RenderTransformOrigin="0.5,0.5"
                                     IsHitTestVisible="False" Visibility="Collapsed">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>

                            <!-- Success: галочка -->
                            <Border x:Name="SuccessCheck" 
                                    Background="#22c55e" CornerRadius="12"
                                    Width="24" Height="24" IsHitTestVisible="False"
                                    Visibility="Collapsed" HorizontalAlignment="Right"
                                    VerticalAlignment="Top" Margin="0,30,30,0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="SuccessCheckScale" ScaleX="0" ScaleY="0"/>
                                </Border.RenderTransform>
                                <Path Data="{StaticResource CheckmarkIcon}" 
                                      Fill="White"
                                      Width="14" Height="14"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Border>

                            <!-- Error: красное пунктирное кольцо -->
                            <Ellipse x:Name="ErrorRing" Width="188" Height="188"
                                     Stroke="#ef4444" StrokeThickness="2.5"
                                     StrokeDashArray="12 8" Fill="Transparent"
                                     IsHitTestVisible="False" Visibility="Collapsed" Opacity="0.7"/>

                            <!-- Совместимость со старым кодом -->
                            <Border x:Name="GlowOuter" Visibility="Collapsed"/>
                            <Border x:Name="GlowMid"   Visibility="Collapsed"/>
                            <Border x:Name="GlowInner" Visibility="Collapsed"/>
                        </Grid>

                        <!-- Progress -->
                        <ProgressBar x:Name="SetupProg" Value="0" Maximum="100" Margin="0,16,0,0"/>
                        <TextBlock x:Name="SetupProgLbl" Text="" FontSize="12"
                                   Foreground="#888888" Margin="0,5,0,0"/>

                        <!-- Separator -->
                        <Border Height="1" Background="#333333" Margin="0,24,0,0"/>

                        <!-- Log header -->
                        <Grid Margin="0,16,0,0">
                            <TextBlock Text="Лог" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="Bold" Foreground="#888888" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Скопировать" Style="{StaticResource FlatBtn}" FontSize="11"
                                        Height="24" Padding="8,2" Margin="0,0,8,0"
                                        WindowChrome.IsHitTestVisibleInChrome="True"
                                        Click="CopyLog_Click"/>
                                <Button Content="Очистить" Style="{StaticResource FlatBtn}" FontSize="11"
                                        Height="24" Padding="8,2"
                                        WindowChrome.IsHitTestVisibleInChrome="True"
                                        Click="ClearLog_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- Log box -->
                        <RichTextBox x:Name="LogBox" Style="{StaticResource LogBox}"
                                     Height="270" Margin="0,8,0,16">
                            <FlowDocument PagePadding="0"/>
                        </RichTextBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- ── FAQ PAGE ── -->
                <!-- ── FAQ PAGE ── -->
                <Grid x:Name="FaqPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="32,20,32,0">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="FaqBackBtn" Style="{StaticResource BackBtn}"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Click="FaqBackBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource ArrowLeftIcon}" 
                                          Stroke="#888888"
                                          StrokeThickness="2"
                                          
                                          Width="14" Height="14"
                                          Stretch="Uniform"
                                          Margin="0,0,6,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Назад" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="FaqHeaderTitle" Text="Частые вопросы" FontFamily="Segoe UI" FontSize="18"
                                       FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="#333333" Margin="32,14,32,0"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="32,14,32,0">
                        <StackPanel x:Name="FaqContainer" Margin="0,0,0,20"/>
                    </ScrollViewer>
                </Grid>

                <!-- ── SOLUTION PAGE ── -->
                <Grid x:Name="SolutionPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Title bar -->
                    <Grid Grid.Row="0" Margin="32,20,32,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource BackBtn}"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Click="BackFromSolution_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource ArrowLeftIcon}" 
                                          Stroke="#888888"
                                          StrokeThickness="2"
                                          
                                          Width="14" Height="14"
                                          Stretch="Uniform"
                                          Margin="0,0,6,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Назад" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="SolutionTitle" Text="Решение проблемы" FontFamily="Segoe UI" FontSize="18"
                                       FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="#333333" Margin="32,14,32,0"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="32,14,32,0">
                        <StackPanel Margin="0,0,0,32">
                            <!-- Auto -->
                            <TextBlock Text="Автоматическое решение" FontFamily="Segoe UI" FontSize="15"
                                       FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                            <Button x:Name="SolutionAutoFixBtn"
                                    Style="{StaticResource AccentBtn}" HorizontalAlignment="Left"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Click="SolutionAutoFixBtn_Click" Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource BoltIcon}" 
                                          Fill="White"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Исправить в один клик" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Border Height="1" Background="#333333" Margin="0,0,0,24"/>

                            <!-- Manual -->
                            <TextBlock Text="Ручное решение" FontFamily="Segoe UI" FontSize="15"
                                       FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                            
                            <Border Background="#1e1e1e" BorderBrush="#3b82f6" BorderThickness="2,0,0,0"
                                    CornerRadius="6" Padding="16" Margin="0,0,0,0">
                                <TextBlock x:Name="SolutionManualText" Text="..."
                                           FontFamily="Segoe UI" FontSize="13" Foreground="#cccccc"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ── DIAGNOSTICS PAGE ── -->
                <Grid x:Name="DiagPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Title bar -->
                    <Grid Grid.Row="0" Margin="32,20,32,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource BackBtn}"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Click="BackBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource ArrowLeftIcon}" 
                                          Stroke="#888888"
                                          StrokeThickness="2"
                                          
                                          Width="14" Height="14"
                                          Stretch="Uniform"
                                          Margin="0,0,6,0"
                                          VerticalAlignment="Center"/>
