                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="38" Height="38" CornerRadius="10"
                                                Background="#1a2a3a" Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="T" FontFamily="Segoe UI"
                                                       FontSize="17" FontWeight="Bold"
                                                       Foreground="#3b82f6"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="tg-ws-proxy"
                                                       FontFamily="Segoe UI" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="White"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <Ellipse x:Name="TgWsDot2" Width="6" Height="6"
                                                         Fill="#888888" VerticalAlignment="Center"
                                                         Margin="0,0,5,0"/>
                                                <TextBlock x:Name="TgWsStatusLbl"
                                                           Text="Не запущен"
                                                           FontFamily="Segoe UI" FontSize="11"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button x:Name="TgWsToggleBtn" Grid.Column="2"
                                                Style="{StaticResource AccentBtn}"
                                                Padding="12,7" FontSize="12"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Click="TgWsToggle_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource PlayIcon}" 
                                                      Fill="White"
                                                      Width="12" Height="12"
                                                      Stretch="Uniform"
                                                      Margin="0,0,6,0"
                                                      VerticalAlignment="Center"/>
                                                <TextBlock Text="Запустить" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    
                                    <!-- Прогресс-бар для переключения TgWsProxy -->
                                    <ProgressBar x:Name="TgWsToggleProgress"
                                                 Height="3"
                                                 Margin="0,8,0,0"
                                                 IsIndeterminate="True"
                                                 Visibility="Collapsed"
                                                 Foreground="#3b82f6"
                                                 Background="#1a1a1c"
                                                 BorderThickness="0"/>
                                </StackPanel>
                            </Border>

                            <!-- Zapret Config Buttons -->
                            <TextBlock Text="Настройка Zapret" 
                                       FontFamily="Segoe UI" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#888888" 
                                       Margin="0,16,0,8"/>
                            
                            <!-- Selected Config Display -->
                            <TextBlock x:Name="SelectedConfigText"
                                       FontFamily="Segoe UI" FontSize="14"
                                       FontWeight="SemiBold" Foreground="#f0f0f0" 
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"/>
                            
                            <!-- Select Config Button (теперь первая, с акцентным стилем) -->
                            <Button x:Name="SelectConfigBtn"
                                    Style="{StaticResource AccentBtn}"
                                    Padding="14,12"
                                    Margin="0,0,0,8"
                                    HorizontalContentAlignment="Left"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Click="SelectConfigBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource SettingsIcon}" 
                                          Fill="White"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Выбрать конфиг" 
                                               FontFamily="Segoe UI" FontSize="13"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Test Configs Button (теперь вторая, с outline стилем) -->
                            <Button x:Name="TestConfigsBtn"
                                    Style="{StaticResource OutlineBtn}"
                                    Padding="14,12"
                                    HorizontalContentAlignment="Left"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Click="TestConfigsBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource SearchIcon}" 
                                          Stroke="#888888"
                                          StrokeThickness="1.5"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Начать сканирование" 
                                               FontFamily="Segoe UI" FontSize="13"
                                               Foreground="#888888" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Активный конфиг -->
                            <TextBlock x:Name="ActiveConfigText" 
                                       Margin="0,12,0,0"
                                       FontSize="12"
                                       Visibility="Collapsed">
                                <Run Text="Включен конфиг: " Foreground="#888888"/>
                                <Run x:Name="ActiveConfigName" Text="" Foreground="#22c55e"/>
                            </TextBlock>

                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
